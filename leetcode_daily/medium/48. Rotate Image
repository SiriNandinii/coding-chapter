"""
48. Rotate Image
Medium

Problem:
You are given an n x n 2D matrix representing an image.

Rotate the image by 90 degrees clockwise.

You must do this in-place (modify the matrix directly),
without using extra space.

--------------------------------------------------------

Example 1:
Input:
matrix = [
 [1,2,3],
 [4,5,6],
 [7,8,9]
]

Output:
[
 [7,4,1],
 [8,5,2],
 [9,6,3]
]

--------------------------------------------------------

Example 2:
Input:
matrix = [
 [5,1,9,11],
 [2,4,8,10],
 [13,3,6,7],
 [15,14,12,16]
]

Output:
[
 [15,13,2,5],
 [14,3,4,1],
 [12,6,8,9],
 [16,7,10,11]
]

--------------------------------------------------------

Approach:
Two Steps:

1. Transpose the matrix
   (swap matrix[i][j] with matrix[j][i])

2. Reverse each row

--------------------------------------------------------

Time Complexity: O(n²)
Space Complexity: O(1)
"""


class Solution:
    def rotate(self, matrix):

        n = len(matrix)

        # Step 1: Transpose
        for i in range(n):
            for j in range(i, n):
                matrix[i][j], matrix[j][i] = matrix[j][i], matrix[i][j]

        # Step 2: Reverse each row
        for i in range(n):
            matrix[i].reverse()
