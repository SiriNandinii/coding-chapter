class Solution:
    def myAtoi(self, s: str) -> int:

        s = s.lstrip()
        if s is None:
            return 0
        
        if len(s)<=0:
            return 0
        
        #sign handling
        sign = 1
        index = 0
        if s[0] == '-':
            sign = -1
            index += 1

        elif s[0] == '+':
            sign = 1
            index += 1

        result = 0
        
        while index<len(s) and s[index].isdigit():
            result = result*10 + int(s[index])
            index += 1

        result *= sign
        
        MIN, MAX = -2**31, 2**31 - 1

        if result<MIN:
            return MIN
        if result>MAX:
            return MAX
        
        return result
