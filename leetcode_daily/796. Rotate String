"""
796. Rotate String
Easy

Problem:
Given two strings s and goal, return true if and only if s can become
goal after some number of shifts on s.

A shift on s consists of moving the leftmost character of s
to the rightmost position.

Example 1:
Input: s = "abcde", goal = "cdeab"
Output: true

Example 2:
Input: s = "abcde", goal = "abced"
Output: false

Constraints:
1 <= s.length, goal.length <= 100
s and goal consist of lowercase English letters.

Approach:
- Convert string into list
- Rotate one character at a time
- Compare with goal after every rotation
- Return True if matched

Time Complexity: O(n²)
Space Complexity: O(n)
"""


class Solution:
    def rotateString(self, s: str, goal: str) -> bool:
        s = list(s)

        for i in range(len(s)):
            s.append(s[0])
            s = s[1:]

            if "".join(s) == goal:
                return True

        return False
