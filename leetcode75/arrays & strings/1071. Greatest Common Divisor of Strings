"""
1071. Greatest Common Divisor of Strings
Easy

Problem:
For two strings s and t, we say "t divides s"
if s is formed by repeating t one or more times.

Return the largest string x such that
x divides both str1 and str2.

--------------------------------------------------------

Example 1:
Input:
str1 = "ABCABC"
str2 = "ABC"

Output:
"ABC"

--------------------------------------------------------

Example 2:
Input:
str1 = "ABABAB"
str2 = "ABAB"

Output:
"AB"

--------------------------------------------------------

Example 3:
Input:
str1 = "LEET"
str2 = "CODE"

Output:
""

--------------------------------------------------------

Approach:
- If str1 + str2 != str2 + str1,
  no common divisor exists.
- Find GCD of lengths.
- Return substring of that length.

--------------------------------------------------------

Time Complexity: O(n)
Space Complexity: O(1)
"""

from math import gcd


class Solution:
    def gcdOfStrings(self, str1: str, str2: str) -> str:

        if str1 + str2 != str2 + str1:
            return ""

        length = gcd(len(str1), len(str2))

        return str1[:length]
