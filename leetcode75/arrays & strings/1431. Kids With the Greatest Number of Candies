"""
1431. Kids With the Greatest Number of Candies
Easy

Problem:
Given an array candies where candies[i]
represents candies owned by the ith kid,
and an integer extraCandies.

Return a boolean list where result[i] is True
if giving all extraCandies to kid i makes them
have the greatest number of candies.

--------------------------------------------------------

Example 1:
Input:
candies = [2,3,5,1,3]
extraCandies = 3

Output:
[True, True, True, False, True]

--------------------------------------------------------

Approach:
- Find maximum candies among all kids.
- Check for every kid:
    candies[i] + extraCandies >= maximum

--------------------------------------------------------

Time Complexity: O(n)
Space Complexity: O(n)
"""

from typing import List


class Solution:
    def kidsWithCandies(
        self,
        candies: List[int],
        extraCandies: int
    ) -> List[bool]:

        maximum = max(candies)

        result = []

        for candy in candies:
            result.append(candy + extraCandies >= maximum)

        return result
