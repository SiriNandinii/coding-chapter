"""
1493. Longest Subarray of 1's After Deleting One Element
Medium

Problem:
Given a binary array nums,
delete exactly one element.

Return the length of the longest subarray
containing only 1's.

--------------------------------------------------------

Example 1:
Input:
nums = [1,1,0,1]

Output:
3

--------------------------------------------------------

Example 2:
Input:
nums = [0,1,1,1,0,1,1,0,1]

Output:
5

--------------------------------------------------------

Example 3:
Input:
nums = [1,1,1]

Output:
2

--------------------------------------------------------

Approach:
Sliding Window

- Allow at most one zero in window
- If zeros > 1:
    shrink window
- Result = window size - 1 (one deletion)

--------------------------------------------------------

Time Complexity: O(n)
Space Complexity: O(1)
"""

from typing import List


class Solution:
    def longestSubarray(self, nums: List[int]) -> int:

        left = 0
        zeros = 0
        maximum = 0

        for right in range(len(nums)):

            if nums[right] == 0:
                zeros += 1

            while zeros > 1:
                if nums[left] == 0:
                    zeros -= 1
                left += 1

            maximum = max(maximum, right - left)

        return maximum
