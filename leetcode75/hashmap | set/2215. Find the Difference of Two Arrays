"""
2215. Find the Difference of Two Arrays
Easy

Problem:
Given two integer arrays nums1 and nums2,
return a list answer of size 2 where:

- answer[0]:
    distinct integers in nums1
    not present in nums2

- answer[1]:
    distinct integers in nums2
    not present in nums1

--------------------------------------------------------

Example 1:
Input:
nums1 = [1,2,3]
nums2 = [2,4,6]

Output:
[[1,3],[4,6]]

--------------------------------------------------------

Example 2:
Input:
nums1 = [1,2,3,3]
nums2 = [1,1,2,2]

Output:
[[3],[]]

--------------------------------------------------------

Approach:
Sets

- Convert arrays into sets
- Use set difference operation
- Convert result back to list

--------------------------------------------------------

Time Complexity: O(n + m)
Space Complexity: O(n + m)
"""

from typing import List


class Solution:
    def findDifference(
        self,
        nums1: List[int],
        nums2: List[int]
    ) -> List[List[int]]:

        nums1 = set(nums1)
        nums2 = set(nums2)

        a = list(nums1 - nums2)
        b = list(nums2 - nums1)

        return [a, b]
